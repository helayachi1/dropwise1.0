<div class="sensors">
    <div class="sensor_card">
        <div class="sensor_card_title">
            <p>Temperature</p>
            <svg class="temp-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
          </svg>

        </div>
        <span class="sensor_card_value"><%= @sensor_readings.temperature %><span style="color: #ccc ">°C</span></span>
    </div>

    <div class="sensor_card">
        <div class="sensor_card_title">
            <p>Humidity</p>

            <svg class="humid-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 0 0 4.5 4.5H18a3.75 3.75 0 0 0 1.332-7.257 3 3 0 0 0-3.758-3.848 5.25 5.25 0 0 0-10.233 2.33A4.502 4.502 0 0 0 2.25 15Z" />
</svg>


        </div>
        <span class="sensor_card_value"><%= @sensor_readings.humidity %><span style="color: #ccc ">%</span></span>
    </div>

     <div class="sensor_card">
        <div class="sensor_card_title">
            <p>Water Level</p>
 <svg class="level-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
  <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 7.5A2.25 2.25 0 0 1 7.5 5.25h9a2.25 2.25 0 0 1 2.25 2.25v9a2.25 2.25 0 0 1-2.25 2.25h-9a2.25 2.25 0 0 1-2.25-2.25v-9Z" />
</svg>

</div>
      
        <span class="sensor_card_value"><%= @sensor_readings.water_level%><span style="color: #ccc ">%</span></span>

     </div>

</div>